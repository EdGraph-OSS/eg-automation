# Enable UV's runtime malware scanning (recommended for all environments).
UV_MALWARE_CHECK=1

# EdGraph environment: Dev | QA | Production | Local
EDGRAPH_ENVIRONMENT=Dev

# OAuth2 client credentials for the EdGraph API (district/tenant-scoped).
# Required by: setup_tenant
EDGRAPH_CLIENT_ID=
EDGRAPH_CLIENT_SECRET=

# OAuth2 client credentials for the ESU EdGraph API.
# Required by: setup_esu
ESU_EDGRAPH_CLIENT_ID=
ESU_EDGRAPH_CLIENT_SECRET=

# Tenant ID of the district to configure.
# Required by: setup_tenant
TENANT_ID=

# School year to provision (e.g. 2026).
SCHOOL_YEAR=

# District name used as a vendor name and in job/connection names.
# Required by: setup_tenant, obfuscated_sync_to_esu
DISTRICT_NAME=

# ESU name (e.g. "ESU 6", "ESU 17").
# Required by: setup_esu, obfuscated_sync_to_esu
ESU_NAME=

# Tenant ID of the ESU to configure.
# Required by: setup_esu, obfuscated_sync_to_esu
ESU_TENANT_ID=

# ID of the pre-provisioned DataSync source connection for NDE/Adviser data.
# Required by: sync_from_sea
NDE_CONNECTION_ID=

# ID of the pre-provisioned DataSync source connection for ACT data.
# Required by: sync_from_act
ACT_CONNECTION_ID=
